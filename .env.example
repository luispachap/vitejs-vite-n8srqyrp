# Plantilla de configuración de Supabase
# Copia este archivo como ".env" y rellena con tus llaves reales

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-llave-anon-aqui

# Cuenta técnica (opcional pero recomendada)
VITE_SUPABASE_APP_EMAIL=app@tu-empresa.com
VITE_SUPABASE_APP_PASSWORD=contraseña-fuerte-aqui
